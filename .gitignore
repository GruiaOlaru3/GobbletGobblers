# ---- Project exceptions ----
# Keep the SFML runtime DLLs that live next to the project source so the
# game can be launched without copying them in manually.
!Gobblet Gobblers/Gobllet/*.dll
# Keep the bundled SFML headers and import libraries (vendored dependency).
!Gobblet Gobblers/External/**

# Runtime-generated game data (profiles, saved game, leaderboard)
